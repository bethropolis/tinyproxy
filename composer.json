{
    "name": "bethropolis/tinyproxy",
    "description": "Lightweight PHP proxy service with caching, content modification, and security features",
    "type": "project",
    "license": "MIT",
    "keywords": ["proxy", "cache", "web-proxy", "http-proxy", "php"],
    "authors": [
        {
            "name": "bethropolis",
            "homepage": "https://github.com/bethropolis"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.8",
        "vlucas/phpdotenv": "^5.6",
        "psr/log": "^3.0",
        "psr/container": "^2.0",
        "symfony/cache": "^6.4",
        "league/uri": "^7.4",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "vimeo/psalm": "^5.20",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "TinyProxy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TinyProxy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src --level=8",
        "phpcs": "phpcs --standard=PSR12 src",
        "phpcbf": "phpcbf --standard=PSR12 src",
        "psalm": "psalm",
        "check": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
